{
  "name": "aurora-demo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @aurora-demo/db db:push",
    "db:studio": "turbo -F @aurora-demo/db db:studio",
    "db:generate": "turbo -F @aurora-demo/db db:generate",
    "db:migrate": "turbo -F @aurora-demo/db db:migrate",
    "db:start": "turbo -F @aurora-demo/db db:start",
    "db:watch": "turbo -F @aurora-demo/db db:watch",
    "db:stop": "turbo -F @aurora-demo/db db:stop",
    "db:down": "turbo -F @aurora-demo/db db:down",
    "check": "biome check --write .",
    "test:e2e": "turbo -F @aurora-demo/e2e test:e2e",
    "test:e2e:headed": "turbo -F @aurora-demo/e2e test:headed"
  },
  "dependencies": {
    "@aurora-demo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aurora-demo/config": "workspace:*",
    "@biomejs/biome": "^2.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "catalog:",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.0.0",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.3.6"
}
